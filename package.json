{
  "name": "logicompare",
  "version": "1.1.4",
  "description": "LogiCompare - Aplicación de escritorio para calcular y comparar tarifas logísticas",
  "main": "src/main/main.js",
  "scripts": {
    "start": "concurrently -k -s first \"npm run vite\" \"npm run electron:wait\"",
    "vite": "vite",
    "electron": "cross-env NODE_ENV=development electron .",
    "electron:wait": "wait-on http://localhost:5173 -t 30000 && cross-env NODE_ENV=development electron .",
    "build": "vite build && electron-builder",
    "build:clean": "node -e \"require('fs').rmSync('release',{recursive:true,force:true})\" & vite build && electron-builder",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "seed:gls": "electron . --seed",
    "seed:logistica": "electron . --seed-logistica",
    "seed:dhl": "electron . --seed-dhl",
    "seed:seur": "electron . --seed-seur",
    "seed:transhaer": "electron . --seed-transhaer",
    "seed:transabadell": "electron . --seed-transabadell",
    "preview:splash": "cross-env NODE_ENV=development electron . --splash"
  },
  "keywords": [
    "electron",
    "logistics",
    "shipping",
    "rates"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^29.4.6",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^3.4.3",
    "vite": "^5.2.8",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "chart.js": "^4.5.1",
    "xlsx": "^0.18.5"
  },
  "build": {
    "appId": "com.logicompare.app",
    "productName": "LogiCompare",
    "copyright": "Copyright © 2025 LogiCompare",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/main/**/*",
      "src/renderer/dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "src/main/assets",
        "to": "assets"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "forceCodeSigning": false,
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "LogiCompare",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "deleteAppDataOnUninstall": false
    }
  }
}
